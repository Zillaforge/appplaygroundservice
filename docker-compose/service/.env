GOPROXY="https://proxy.golang.org|http://proxy.pegasus-cloud.com:8078|http://goproxy:8078"

OWNER=Zillaforge

IAM_FOLDER_NAME=pegasusiam
EPP_FOLDER_NAME=eventpublishplugin
APS_FOLDER_NAME=appplaygroundservice
VPS_FOLDER_NAME=virtualplatformservice
VRM_FOLDER_NAME=virtualregistrymanagement

EPP_DISABLE=true                # comment this line to enable EPP service
# EPP_RELEASE_DISABLE=true      # comment this line to enable EPP release service

IAM_DISABLE=true                # comment this line to enable IAM service
# IAM_RELEASE_DISABLE=true      # comment this line to enable IAM release service

APS_DISABLE=true                # comment this line to enable APS service
# APS_RELEASE_DISABLE=true      # comment this line to enable APS release service

VRM_DISABLE=true                # comment this line to enable VRM service
# VRM_RELEASE_DISABLE=true      # comment this line to enable VRM release service

VPS_DISABLE=true                # comment this line to enable VPS service
# VPS_RELEASE_DISABLE=true      # comment this line to enable VPS release service